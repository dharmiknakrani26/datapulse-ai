# DataPulse AI - Git Ignore

# Environment Variables / Secrets
.env
.env.*
!.env.example


# Python
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/

.coverage
.coverage.*
htmlcov/

*.egg-info/
dist/
build/


# DataPulse Runtime Data
backend/data/incident_history.json
backend/data/*.tmp


# Local Uploaded Data
data_uploads/*
!data_uploads/.gitkeep


# Local DataHub Configuration
scripts/datahub-auth-compose.yml


# Next.js / Node
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# IDE / Editor
.vscode/
.idea/

*.swp
*.swo


# Operating System
.DS_Store
Thumbs.db
desktop.ini